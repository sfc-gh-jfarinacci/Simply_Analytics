# Simply Analytics - Local Development Environment

# Server
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Authentication (JWT session signing key - HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=6266d172f33a94c031f134b8e5c95037b021936aa87600eabc9fe3efed30fa20f90edc6326ee3a34d8efbffd9434a17050a55802d594fee28b7c13fbfd81c588
JWT_EXPIRY=8h
# Credential Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=d9ff829cd12792410ba7fe248147cabc13e050d1baab918c5ececa7694ab131d


# SSL/TLS Settings
# Enable this for corporate proxy/VPN with self-signed certificates
SNOWFLAKE_INSECURE_CONNECT=true
# Metadata Backend: "postgres" or "snowflake"
METADATA_BACKEND=postgres
# Snowflake Service Account (used when METADATA_BACKEND=snowflake)
# Auth types:  pat, keypair
SF_SERVICE_AUTH_TYPE=keypair
SF_SERVICE_ACCOUNT=your-account-here
SF_SERVICE_USER=SIMPLY_SVC_USER
SF_SERVICE_PRIVATE_KEY_PATH=./keys/rsa_key.p8
SF_SERVICE_PRIVATE_KEY_PASS=
SF_SERVICE_ROLE=SIMPLY_SVC_ROLE
SF_SERVICE_WAREHOUSE=SIMPLY_WH
SF_SERVICE_DATABASE=SIMPLY_ANALYTICS
SF_SERVICE_SCHEMA=APP

# PostgreSQL (used when METADATA_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=simply_analytics
POSTGRES_USER=jfarinacci
POSTGRES_PASSWORD=test1234

# SSO / SAML 2.0 (Okta, Entra ID, etc.)
SSO_ENABLED=false
SAML_ENTRYPOINT=https://your-idp.example.com/sso/saml
SAML_ISSUER=simply-analytics
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:3001/api/saml/callback

# SCIM 2.0 User Provisioning
SCIM_ENABLED=false
SCIM_BEARER_TOKEN=generate-a-secure-random-token-here